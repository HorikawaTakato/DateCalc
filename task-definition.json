{
  "family": "datecalc-task",
  "executionRoleArn": "__EXECUTION_ROLE_ARN__",
  "networkMode": "bridge",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "ghcr.io/horikawatakato/datecalc:latest",
      "cpu": 256,
      "memory": 200,
      "memoryReservation": 100,
      "portMappings": [],
      "environment": [
        {
          "name": "TZ",
          "value": "Asia/Tokyo"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/datecalc",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "nginx",
      "image": "ghcr.io/horikawatakato/datecalc-nginx:latest",
      "cpu": 128,
      "memory": 100,
      "memoryReservation": 50,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "TZ",
          "value": "Asia/Tokyo"
        }
      ],
      "essential": true,
      "links": ["web:web"],
      "dependsOn": [
        {
          "containerName": "web",
          "condition": "START"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/datecalc",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "ecs-nginx"
        }
      }
    }
  ],
  "requiresCompatibilities": ["EC2"]
}
